OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-nano

# API Server Config
API_HOST=0.0.0.0
API_PORT=8000

# thresholds and constraints
EXTRACTION_CONFIDENCE_THRESHOLD=0.95
CRITICAL_RECALL_FLOOR=1.0
PRECISION_TARGET=0.99

# Engine config
KB_VERSION=v2026.04.01-LTS
RXNORM_DB_PATH=kb/rxnorm.db
SNOMED_DB_PATH=kb/snomed.db
DDI_RULES_PATH=kb/ddi_rules.json